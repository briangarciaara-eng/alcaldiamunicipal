{
  "version": 2,
  "builds": [
    {
      "src": "servidor.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/servidor.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "functions": {
    "servidor.py": {
      "runtime": "python3.11",
      "maxDuration": 30,
      "memory": 1024
    }
  }
}